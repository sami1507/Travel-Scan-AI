# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI (Required for AI-powered analysis)
OPENAI_API_KEY=your_openai_api_key

# Duffel (Required for real flight data)
DUFFEL_API_TOKEN=your_duffel_api_token
DUFFEL_ENVIRONMENT=test

# Hotelbeds (Required for real hotel data)
HOTELBEDS_API_KEY=your_hotelbeds_api_key
HOTELBEDS_API_SECRET=your_hotelbeds_api_secret
HOTELBEDS_ENVIRONMENT=test

# Google Maps (Required for route visualization)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# App URL (Update for production deployment)
NEXT_PUBLIC_APP_URL=http://localhost:3000
