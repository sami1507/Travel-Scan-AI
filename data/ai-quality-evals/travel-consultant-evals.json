{
  "version": "1.0.0",
  "description": "AI Travel Consultant Quality Evaluation Dataset",
  "testCases": [
    {
      "id": "eval-001",
      "name": "City + History + Food, 7 days, Autumn, Moderate",
      "input": {
        "departureCity": "Tel Aviv",
        "passportCountry": "Israel",
        "tripLength": 7,
        "season": "autumn",
        "months": [9, 10, 11],
        "budget": "moderate",
        "tripStructure": "single-country-multi-city",
        "interests": ["history", "food", "city"],
        "accommodationPreference": "hotel"
      },
      "expectedBehavior": {
        "mustHave3Recommendations": true,
        "mustHaveRoutes": true,
        "mustHaveAtLeast2Regions": true,
        "mustHaveUniqueOption": true,
        "mustNotAllBeMainstreamMediterranean": true,
        "mustExplainWhy": true,
        "mustIncludeBeforeYouBookWarnings": true,
        "maxGenericPhraseCount": 1,
        "fallbackAllowed": false,
        "minQualityScore": 75
      },
      "notes": "Core use case - should demonstrate diversity and consultant quality"
    },
